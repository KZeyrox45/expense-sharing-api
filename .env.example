# ================================================================
# App
# ================================================================
APP_ENV=development                          # development | production
SECRET_KEY=your-secret-key-min-32-chars     # Generate: openssl rand -hex 32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ================================================================
# Database — PostgreSQL
# ================================================================
POSTGRES_USER=expense_user
POSTGRES_PASSWORD=expense_password
POSTGRES_DB=expense_sharing
POSTGRES_HOST=db                            # Service name in docker-compose
POSTGRES_PORT=5432
# SQLAlchemy async URL - must use asyncpg driver
DATABASE_URL=postgresql+asyncpg://expense_user:expense_password@db:5432/expense_sharing

# ================================================================
# Redis
# ================================================================
# DB 0: general caching (preventive)
# DB 1: Celery broker (where the task is sent)
# DB 2: Celery result backend (where task results are saved)
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ================================================================
# Email - Use Mailtrap for development (https://mailtrap.io)
# Mailtrap catch whole email, no sending it out
# ================================================================
MAIL_USERNAME=your_mailtrap_username
MAIL_PASSWORD=your_mailtrap_password
MAIL_FROM=noreply@expensesharing.dev
MAIL_PORT=587
MAIL_SERVER=sandbox.smtp.mailtrap.io
MAIL_STARTTLS=True
MAIL_SSL_TLS=False